# Copy this file to .env and fill in your values

# Your Gmail address
EMAIL_SENDER=you@gmail.com

# Gmail App Password (NOT your regular password)
# How to get one: myaccount.google.com -> Security -> 2-Step Verification -> App Passwords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Who receives the digest (can be multiple, comma-separated)
EMAIL_RECIPIENT=you@yourdomain.com

# Adzuna API (free at developer.adzuna.com — no credit card needed)
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
